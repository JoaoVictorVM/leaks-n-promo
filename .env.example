# Configuração do leaks&promo (12-factor).
# Copie para .env e preencha. O .env é gitignored e NUNCA deve ser commitado.

# --- Discord (obrigatório) ---
# Token do bot. Gere em https://discord.com/developers/applications (aba Bot).
DISCORD_TOKEN=

# ID da aplicação (Application ID), usado no registro dos slash commands.
DISCORD_APP_ID=

# ID do servidor para registro de comandos durante o desenvolvimento.
# Comandos de guild propagam na hora; deixe vazio para registro global (pode
# levar até ~1h para propagar).
DISCORD_GUILD_ID=

# --- Aplicação ---
# Nível de log: debug | info | warn | error
LOG_LEVEL=info

# TTL do cache em memória (ex.: 5m, 30s, 1h).
CACHE_TTL=5m

# Timeout das chamadas HTTP às fontes externas (ex.: 10s).
HTTP_TIMEOUT=10s

# --- HTTP ---
# User-Agent enviado em todas as requisições às fontes (CheapShark, RSS, Reddit).
# O CheapShark exige um User-Agent.
HTTP_USER_AGENT=leaks-n-promo/0.1 (+https://github.com/JoaoVictorVM/leaks-n-promo)

# --- Leaks ---
# Feeds RSS a consultar, separados por vírgula. Vazio = usa a lista padrão do bot.
LEAK_RSS_FEEDS=

# --- Reddit (opcional, enhancement) ---
# Só preencha se/quando o app for aprovado pelo Reddit. Sem isso, o bot usa
# apenas RSS como fonte de leaks.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
